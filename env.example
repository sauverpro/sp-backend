# Server
PORT=5000

# Database
DB_CONNECT=mongodb://localhost:27017/sp_gas
DB_CONNECT_DIRECT=
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

# Auth
JWT_SECRETE=replace_with_strong_secret
JWT_EXP=7d

# Password hashing
slatRound=10

# Cloudinary
CLOUD_NAME=your_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRETE=your_cloudinary_api_secret

# Mailer
MAILER_SERVICE=gmail
MAILER_AUTH_USER=your_email@example.com
MAILER_AUTH_PASS=your_email_password_or_app_password

# Paypack (legacy keys used in cart/payment controllers)
CLIENT_ID=your_paypack_client_id
CLIENT_SECRETE=your_paypack_client_secret

# Paypack (keys used in callback controller)
PAYPACK_CLIENT_ID=your_paypack_client_id
PAYPACK_CLIENT_SECRET=your_paypack_client_secret